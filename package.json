{
  "name": "pseudo-kit",
  "version": "0.2.0",
  "description": "Vanilla HTML component system for pseudo-HTML layout descriptors. No build step. No framework.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".":             "./src/client/pseudo-kit-client.js",
    "./client":      "./src/client/pseudo-kit-client.js",
    "./server":      "./src/server/pseudo-kit-server.js",
    "./validator":   "./src/server/canvas-validator.js",
    "./normalizer":  "./src/server/canvas-normalize.js",
    "./shared":      "./src/shared/index.js"
  },
  "files": [
    "src/",
    "README.md"
  ],
  "scripts": {
    "validate":        "node src/server/canvas-validator.js",
    "validate:json":   "node src/server/canvas-validator.js --json",
    "normalize":       "node src/server/canvas-normalize.js",
    "normalize:write": "node src/server/canvas-normalize.js --in-place",
    "test":         "node --test tests/registry-shared.test.js tests/state-shared.test.js tests/pseudo-kit-server.test.js tests/canvas-validator.test.js tests/canvas-normalize.test.js tests/pseudo-assets-index.test.js",
    "test:client":  "vitest run tests/pseudo-kit-client.client.test.js",
    "test:all":     "pnpm test && pnpm run test:client",
    "test:coverage":"vitest run --coverage"
  },
  "devDependencies": {
    "vitest":    "^2.0.0",
    "happy-dom": "^14.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "pseudo-kit",
    "pseudo-html",
    "web-components",
    "vanilla",
    "no-framework",
    "ssr"
  ]
}
